# ─── Copy file ini menjadi .env lalu isi semua nilai di bawah ────────────────
# cp .env.example .env

# ─── Qwen / DashScope ─────────────────────────────────────────────────────────
# Dapatkan API key dari: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── ApsaraDB RDS for MySQL ───────────────────────────────────────────────────
# Dapatkan dari: Alibaba Cloud Console → ApsaraDB RDS → Instance Connection
# Gunakan "Internal Endpoint" jika backend dan DB berada di VPC yang sama (lebih cepat & aman)
# Gunakan "Public Endpoint" jika backend berjalan di mesin lokal / luar VPC

DB_HOST=rm-gs5f86ilb9ibdl7kv.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_USER=finlabs_user
DB_PASSWORD=YourStrongPasswordHere
DB_NAME=finlabs

# Set ke "true" untuk mengaktifkan SSL (WAJIB untuk koneksi public endpoint ApsaraDB)
DB_SSL=true

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
